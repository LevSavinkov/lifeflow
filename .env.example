# ─── Backend ──────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/lifeflow

# Включает SQL-логи и debug-режим FastAPI (по умолчанию false)
# DEBUG=true
# Автосоздание таблиц через SQLAlchemy при старте приложения.
# В проде оставляйте false и используйте только alembic upgrade head.
# AUTO_CREATE_SCHEMA=true

# CORS: разрешённые origin'ы для браузерных запросов.
# По умолчанию — любой http/https origin (удобно для разработки и LAN-доступа).
# В проде замените на конкретный домен:
#   CORS_ALLOW_ORIGIN_REGEX=https://myapp\.example\.com
# CORS_ALLOW_ORIGIN_REGEX=https?://.*

# Auth (JWT + refresh sessions)
# В проде обязательно замените секрет.
# JWT_SECRET=super-long-random-secret
# JWT_ALG=HS256
# ACCESS_TTL_MIN=15
# REFRESH_TTL_DAYS=30
#
# Cookie policy
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=example.com
# COOKIE_PATH=/
#
# Rate limits
# RATE_LIMIT_LOGIN_PER_MIN=10
# RATE_LIMIT_REFRESH_PER_MIN=30

# ─── Frontend ─────────────────────────────────────────────────────────────────

# Явный адрес бэкенда. Если не задано — фронтенд использует
# http://<hostname браузера>:8000 (работает при LAN-доступе по IP сервера).
# VITE_API_BASE=http://localhost:8000
